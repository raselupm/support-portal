# SMTP & Testing Email (Mailtrap or Postmark)
MAILTRAP_TOKEN=1
MAILTRAP_USER=
MAILTRAP_PASS=
MAILTRAP_FROM_EMAIL=

#POSTMARK_SMTP_TOKEN=
#POSTMARK_FROM_EMAIL=


# ── Image Storage (optional) ──────────────────────────────────────────────────
# Set STORAGE_DRIVER to enable image uploads in the article editor.
# Options: aws | digital-ocean | cloudinary
#STORAGE_DRIVER=
#NEXT_PUBLIC_STORAGE_DRIVER=

# AWS S3
#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=
#AWS_REGION=us-east-1
#AWS_BUCKET=

# DigitalOcean Spaces (S3-compatible)
#DO_SPACES_KEY=
#DO_SPACES_SECRET=
#DO_SPACES_REGION=sfo3
#DO_SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
#DO_SPACES_BUCKET=

# Cloudinary
#CLOUDINARY_CLOUD_NAME=
#CLOUDINARY_API_KEY=
#CLOUDINARY_API_SECRET=


# Database
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

PRODUCTS="Product A,Product B,Product C"
ADMIN_EMAILS=
SESSION_SECRET=change-this-to-a-very-long-random-secret-at-least-32-chars

NEXT_PUBLIC_APP_NAME="Support Portal"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth — create credentials at https://console.cloud.google.com
# Add authorized redirect URI: ${NEXT_PUBLIC_APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Pusher — get free credentials at https://pusher.com (Sandbox plan)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# Rate limits (users only, not admin/staff)
MAX_OPEN_TICKETS_PER_USER=3
MAX_WAITING_CHATS_PER_IP=2
MAX_CHAT_MESSAGES_PER_SECOND=3
